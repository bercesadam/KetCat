#pragma once
#include <SDL2/SDL.h>
#include <SDL2/SDL_ttf.h>
#include <vector>
#include <complex>
#include <cmath>
#include <string>
#include <sstream>

#include "hilbert_space/state_vector.h"
#include "hilbert_space/polar_hilbert.h"

#include "colormaps.h"

namespace KetCat::Visu
{
    template<dimension_t RadialSteps, dimension_t AngularSteps, float_t Radius>
    class PolarWavefunctionViewer
    {
        using HilbertSpace = PolarHilbertSpace<RadialSteps, AngularSteps, Radius>;

    public:
        enum class Mode
        {
            Probability,
            Phase,
            ReIm
        };

        PolarWavefunctionViewer(int windowSize)
            : m_winSize(windowSize)
        {
            SDL_Init(SDL_INIT_VIDEO);
            TTF_Init();

            m_window = SDL_CreateWindow(
                "Polar Wavefunction Viewer",
                SDL_WINDOWPOS_CENTERED,
                SDL_WINDOWPOS_CENTERED,
                windowSize,
                windowSize,
                SDL_WINDOW_SHOWN
            );

            m_renderer = SDL_CreateRenderer(m_window, -1, SDL_RENDERER_ACCELERATED);

            m_font = TTF_OpenFont("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", 16);

            m_radius = windowSize / 2 - 10; // kicsit beljebb a széltől
        }

        ~PolarWavefunctionViewer()
        {
            TTF_CloseFont(m_font);
            SDL_DestroyRenderer(m_renderer);
            SDL_DestroyWindow(m_window);
            TTF_Quit();
            SDL_Quit();
        }

        bool running() const { return m_running; }

        void handleEvent(const SDL_Event& e)
        {
            if (e.type == SDL_QUIT) m_running = false;

            if (e.type == SDL_KEYDOWN)
            {
                switch (e.key.keysym.sym)
                {
                case SDLK_ESCAPE: m_running = false; break;
                case SDLK_F1: m_mode = Mode::Probability; break;
                case SDLK_F2: m_mode = Mode::Phase; break;
                case SDLK_F3: m_mode = Mode::ReIm; break;
                }
            }
        }

        void render(const StateVector<HilbertSpace>& psi,
            double time, const std::string& statusLabel)
        {
            SDL_SetRenderDrawColor(m_renderer, 0, 0, 0, 255);
            SDL_RenderClear(m_renderer);

            switch (m_mode)
            {
            case Mode::Probability: drawDualField(
                [&](dimension_t r, dimension_t th) { return heatColor(std::sqrt(psi[HilbertSpace::index(r, th)].normSquared())); },
                [&](dimension_t r, dimension_t th) { return SDL_Color{ 0,0,0,255 }; }); break;

            case Mode::Phase: drawDualField(
                [&](dimension_t r, dimension_t th) {
                const auto& c = psi[HilbertSpace::index(r, th)];
                return phaseColor(std::atan2(c.im, c.re));
            },
                [&](dimension_t r, dimension_t th) { return SDL_Color{ 0,0,0,255 }; }); break;

            case Mode::ReIm: drawDualField(
                [&](dimension_t r, dimension_t th) {
                const auto& c = psi[HilbertSpace::index(r, th)];
                return bipolarColor(c.re);
            },
                [&](dimension_t r, dimension_t th) {
                const auto& c = psi[HilbertSpace::index(r, th)];
                return bipolarColor(c.im);
            }); break;
            }

            drawText(statusLabel, 10, m_winSize - 26);
            drawTime(time);

            SDL_RenderPresent(m_renderer);
        }

    private:

        template<typename F1, typename F2>
        void drawDualField(F1 leftColor, F2 rightColor)
        {
            int cx1 = m_winSize / 4;
            int cx2 = 3 * m_winSize / 4;
            int cy = m_winSize / 2;

            constexpr double dr = HilbertSpace::dr;

            for (dimension_t r_idx = 0; r_idx < RadialSteps; ++r_idx)
            {
                double r = static_cast<double>(r_idx) * dr;

                for (dimension_t th_idx = 0; th_idx < AngularSteps; ++th_idx)
                {
                    double theta = 2.0 * M_PI * th_idx / AngularSteps;

                    int dx = static_cast<int>(r * std::cos(theta) * m_radius);
                    int dy = static_cast<int>(r * std::sin(theta) * m_radius);

                    SDL_Color c1 = leftColor(r_idx, th_idx);
                    SDL_SetRenderDrawColor(m_renderer, c1.r, c1.g, c1.b, 255);
                    SDL_RenderDrawPoint(m_renderer, cx1 + dx, cy + dy);

                    SDL_Color c2 = rightColor(r_idx, th_idx);
                    SDL_SetRenderDrawColor(m_renderer, c2.r, c2.g, c2.b, 255);
                    SDL_RenderDrawPoint(m_renderer, cx2 + dx, cy + dy);
                }
            }
        }

        void drawText(const std::string& text, int x, int y)
        {
            SDL_Color col{ 220,220,220,255 };
            SDL_Surface* surf = TTF_RenderUTF8_Blended(m_font, text.c_str(), col);
            SDL_Texture* tex = SDL_CreateTextureFromSurface(m_renderer, surf);
            SDL_Rect dst{ x, y, surf->w, surf->h };
            SDL_FreeSurface(surf);
            SDL_RenderCopy(m_renderer, tex, nullptr, &dst);
            SDL_DestroyTexture(tex);
        }

        void drawTime(double t)
        {
            std::ostringstream ss;
            ss.precision(3);
            ss << "t = " << t;
            drawText(ss.str(), m_winSize - 10, 10);
        }

    private:
        SDL_Window* m_window = nullptr;
        SDL_Renderer* m_renderer = nullptr;
        TTF_Font* m_font = nullptr;

        int m_winSize;
        int m_radius;

        Mode m_mode = Mode::Probability;
        bool m_running = true;
    };
}
