pragma once
#include <array>
#include <vector>
#include <cstddef>
#include "state_vector.h"

namespace KetCat
{
    /**
     * @brief Generic gate/qudit applier
     *
     * QuditCount quditet kezel, tetszőleges QuditDim dimenzióval.
     * A gate-hez egy külső functort adunk, ami a lokális subset amplitúdókat
     * evolválja (unitary vagy TDSE alapú).
     */
    template<std::size_t QuditCount, std::size_t QuditDim, typename GateFunctor>
    struct QuditGateApplier
    {
        // Globális teljes state vector
        StateVector<QuditCount * QuditDim>& Psi;

        // Mely quditekre hat a gate
        std::vector<std::size_t> QuditIndices;

        // Functor, ami a lokális subset amplitúdókat lépteti
        GateFunctor GateOp;

        QuditGateApplier(StateVector<QuditCount * QuditDim>& psi,
                         const std::vector<std::size_t>& indices,
                         GateFunctor gateOp)
            : Psi(psi), QuditIndices(indices), GateOp(gateOp)
        {}

        void apply() noexcept
        {
            std::size_t subset_size = 1;
            for (std::size_t i = 0; i < QuditIndices.size(); ++i)
                subset_size *= QuditDim;

            std::size_t total_size = 1;
            for (std::size_t i = 0; i < QuditCount; ++i)
                total_size *= QuditDim;

            // ------------------------------------------------
            // Iterate over all "blocks" (fix non-affected qudits)
            // ------------------------------------------------
            for (std::size_t base = 0; base < total_size; ++base)
            {
                bool skip = false;
                // ellenőrizzük, hogy base-ben nincs subset qudit érték !=0
                for (auto idx : QuditIndices)
                {
                    std::size_t val = (base / static_cast<std::size_t>(std::pow(QuditDim, idx))) % QuditDim;
                    if (val != 0) { skip = true; break; }
                }
                if (skip) continue;

                // ------------------------------------------------
                // Gather local amplitudes
                // ------------------------------------------------
                std::vector<complex_t> LocalAmps(subset_size, complex_t::zero());

                for (std::size_t i = 0; i < subset_size; ++i)
                {
                    std::size_t global_idx = base;
                    std::size_t mult = 1;
                    for (std::size_t n = 0; n < QuditIndices.size(); ++n)
                    {
                        std::size_t val = (i / mult) % QuditDim;
                        global_idx += val * static_cast<std::size_t>(std::pow(QuditDim, QuditIndices[n]));
                        mult *= QuditDim;
                    }
                    LocalAmps[i] = Psi[global_idx];
                }

                // ------------------------------------------------
                // Apply the external functor (unitary / TDSE)
                // ------------------------------------------------
                std::vector<complex_t> Evolved = GateOp(LocalAmps);

                // ------------------------------------------------
                // Scatter back to global state
                // ------------------------------------------------
                for (std::size_t i = 0; i < subset_size; ++i)
                {
                    std::size_t global_idx = base;
                    std::size_t mult = 1;
                    for (std::size_t n = 0; n < QuditIndices.size(); ++n)
                    {
                        std::size_t val = (i / mult) % QuditDim;
                        global_idx += val * static_cast<std::size_t>(std::pow(QuditDim, QuditIndices[n]));
                        mult *= QuditDim;
                    }
                    Psi[global_idx] = Evolved[i];
                }
            }
        }
    };
}

#pragma once
#include <vector>
#include <array>
#include <cstddef>
#include <numeric>
#include "state_vector.h"   // a te StateVector osztály
#include "tdse_solver.h"    // a te TDSE megoldó
#include "hamiltonian.h"    // Hamilton operátor osztály

namespace KetCat {

    /**
     * @brief Multi-qudit state vector manager.
     *
     * - N qudit, tetszőleges szintszám
     * - Full state vector representation
     * - Külön qudit amplitúdók kinyerhetők
     * - Hamilton alkalmazható subset quditekre TDSE-vel
     */
    template<std::size_t QuditCount, std::size_t QuditDim>
    struct MultiQuditState {
        using GridHilbertSpace = StateVector<QuditCount*QuditDim>; // teljes state vector

        // Teljes state vector
        StateVector<QuditCount*QuditDim> Psi;

        MultiQuditState() {
            // Kezdőállapot |0,0,...,0>
            std::fill(Psi.begin(), Psi.end(), complex_t::zero());
            Psi[0] = complex_t::one();
        }

        /**
         * @brief Egyetlen qudit amplitúdóinak lekérdezése
         *
         * @param qdit_index melyik qudit (0..QuditCount-1)
         * @return array<QuditDim, complex_t> a qudit amplitúdói
         */
        std::array<complex_t, QuditDim> getQuditAmplitudes(std::size_t qdit_index) const noexcept {
            std::array<complex_t, QuditDim> amps{};
            // összes kombináció
            std::size_t total_dim = 1;
            for (std::size_t i = 0; i < QuditCount; ++i) total_dim *= QuditDim;

            for (std::size_t idx = 0; idx < total_dim; ++idx) {
                std::size_t local = (idx / pow(QuditDim, qdit_index)) % QuditDim;
                amps[local] += Psi[idx];
            }
            return amps;
        }

        /**
         * @brief Több qudit amplitúdóinak lekérdezése adott indexekkel
         *
         * @param indices quditek indexei
         * @return vector<complex_t> amplitúdó tömb (mérete QuditDim^indices.size())
         */
        template<std::size_t N>
        std::vector<complex_t> getQuditSubsetAmplitudes(const std::array<std::size_t, N>& indices) const noexcept {
            std::size_t subset_dim = 1;
            for (auto i : indices) subset_dim *= QuditDim;
            std::vector<complex_t> amps(subset_dim, complex_t::zero());

            std::size_t total_dim = 1;
            for (std::size_t i = 0; i < QuditCount; ++i) total_dim *= QuditDim;

            for (std::size_t idx = 0; idx < total_dim; ++idx) {
                std::size_t sub_idx = 0;
                std::size_t multiplier = 1;
                for (std::size_t n = 0; n < N; ++n) {
                    sub_idx += ((idx / pow(QuditDim, indices[n])) % QuditDim) * multiplier;
                    multiplier *= QuditDim;
                }
                amps[sub_idx] += Psi[idx];
            }

            return amps;
        }

        /**
         * @brief Hamiltonian alkalmazása egy vagy több quditre TDSE-vel
         *
         * @param H hamiltonian a subset quditekhez
         * @param qudit_indices mely quditeket érinti
         * @param dt időlépés
         */
        template<std::size_t N>
        void applyHamiltonianTDSE(const Hamiltonian<QuditDim, N>& H,
                                   const std::array<std::size_t, N>& qudit_indices,
                                   real_t dt) noexcept 
        {
            // 1. kinyerjük az alrendszer amplitúdóit
            std::vector<complex_t> subset_amplitudes = getQuditSubsetAmplitudes(qudit_indices);

            // 2. TDSE solver alkalmazása
            std::vector<complex_t> evolved_subset = TDSESolver<QuditDim, N>::solve(subset_amplitudes, H, dt);

            // 3. visszaírás a teljes state vectorba
            std::size_t total_dim = 1;
            for (std::size_t i = 0; i < QuditCount; ++i) total_dim *= QuditDim;

            for (std::size_t idx = 0; idx < total_dim; ++idx) {
                std::size_t sub_idx = 0;
                std::size_t multiplier = 1;
                for (std::size_t n = 0; n < N; ++n) {
                    sub_idx += ((idx / pow(QuditDim, qudit_indices[n])) % QuditDim) * multiplier;
                    multiplier *= QuditDim;
                }
                Psi[idx] = evolved_subset[sub_idx];
            }
        }
    };
}